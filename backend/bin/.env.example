# =============================================
# 仓库管理系统配置文件
# =============================================
# 开发环境：复制此文件为 .env 并修改
# Docker 部署：通过 docker-compose 自动使用此配置

# 数据库配置
DB_USERNAME=root
DB_PASSWORD=123456

# JWT配置（生产环境请修改为随机密钥）
JWT_SECRET=warehouse-system-jwt-secret-key-2024

# DeepSeek AI API配置（可选）
# 获取地址: https://platform.deepseek.com
AI_API_KEY=sk-your-api-key-here

# 告警阈值
ALERT_LOW_STOCK_THRESHOLD=10
